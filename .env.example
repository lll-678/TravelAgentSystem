CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_BASE_URL=http://localhost:8000
APP_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_AMAP_KEY=your_amap_web_js_api_key_here

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smart_tour_guide
POSTGRES_USER=smart_tour
POSTGRES_PASSWORD=smart_tour_dev
DATABASE_URL=postgresql+psycopg://smart_tour:smart_tour_dev@postgres:5432/smart_tour_guide
DEV_DATABASE_URL=sqlite:///./smart_tour_dev.db

# Redis
REDIS_URL=redis://redis:6379/0

# Map / OSM
OSM_DEFAULT_PLACE=Beijing University of Posts and Telecommunications Shahe Campus, Beijing, China
OSM_FALLBACK_LAT=40.15608
OSM_FALLBACK_LNG=116.28333
OSM_FALLBACK_DIST=1500

# Media
MEDIA_ROOT=media
